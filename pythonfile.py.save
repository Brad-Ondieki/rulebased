diagnosis_symptoms = {
    "Flu": ["Fever", "Cough", "Body aches", "Fatigue", "Sore throat", "Runny nose"],
    "Cold": ["Runny nose", "Sneezing", "Cough", "Sore throat", "Mild headache"],
    "COVID-19": ["Fever", "Cough", "Shortness of breath", "Fatigue", "Loss of taste/smell", "Sore throat"],
    "Asthma": ["Shortness of breath", "Wheezing", "Chest tightness", "Coughing"],
    "Pneumonia": ["Cough", "Fever", "Chills", "Shortness of breath", "Chest pain", "Fatigue"],
    "Migraine": ["Severe headache", "Nausea", "Vomiting", "Sensitivity to light", "Sensitivity to sound"],
    "Diabetes": ["Increased thirst", "Frequent urination", "Fatigue", "Blurred vision", "Unexplained weight loss"],
    "Hypertension": ["Headaches", "Shortness of breath", "Dizziness", "Chest pain"],
    "Gastritis": ["Stomach pain", "Nausea", "Vomiting", "Loss of appetite", "Bloating"],
    "Anxiety": ["Restlessness", "Rapid heartbeat", "Sweating", "Fatigue", "Trouble concentrating", "Irritability"]
}

user_symptoms = input("input symptoms separated by comas: ")
user_symptoms = [symptoms.strip().lower() for symptoms in user_symptoms.split(',')]

def diagnose(user_symptoms, diagnosis_symptoms):

   highest_score = 0
   best_match = None

   for  dignosis, symptoms in diagnosis_symptoms.items():
        score = sum(1 for symptom in user_symptoms if symptom in symptoms)

        if  score > highest_score:
            highest_score = score
            best_match = diagnosis

   return best_match

result = (diagnose(user_symptoms, diagnosis_symptoms))
print(f"you are most likely suffering from: {result}")
